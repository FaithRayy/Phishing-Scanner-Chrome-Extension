{
    "manifest_version": 3,
    "name": "Phishing Scanner",
    "description": "Checks if the current webpage is a potential phish, along with any links on the webpage.",
    "version": "1.0",
    "action": {
        "default_popup": "popup/popup.html"
    },
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-38.png",
        "128": "images/icon-128.png"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "alarms"
    ]
}